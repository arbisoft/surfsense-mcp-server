SURFSENSE_BASE_URL=https://foss-research.local.moneta.dev

# --- Primary auth (stdio): paste a fresh JWT from the SurfSense web UI. ---
# When this expires, paste a new one. The server does not refresh it.
SURFSENSE_JWT=

# --- Optional stdio fallback: email + password auto-login. ---
# If SURFSENSE_JWT is empty and both of these are set, the server will call
# POST /auth/jwt/login, cache the token for TOKEN_TTL seconds, and transparently
# retry once on 401. Intended for CI / long-running stdio sessions.
# HTTP mode ignores these — it only honours Authorization: Bearer headers.
SURFSENSE_EMAIL=
SURFSENSE_PASSWORD=

# Cached-token lifetime for the password-login fallback (seconds, min 60).
# Default is 3300 (55 min), below fastapi-users' typical 60-min JWT expiry.
TOKEN_TTL=3300

# --- HTTP mode (multi-user, hosted): FastMCP's AWSCognitoProvider is the ---
# --- sole auth layer. Required to run `python -m surfsense_mcp http`.   ---
# Validated at startup (see surfsense_mcp/__main__.py:REQUIRED_HTTP_ENV_VARS).
# In the Moneta devstack these are wired by docker-compose.yml + the
# scripts/derive-oidc-endpoints.sh helper; only set them here when running
# the MCP server outside docker.
# MCP_BASE_URL=https://foss-research-mcp.local.moneta.dev
# COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
# COGNITO_AWS_REGION=ap-southeast-1
# OIDC_CLIENT_ID=<reuses the same Cognito app client as oauth2-proxy>
# Optional for confidential Cognito clients; leave unset for public/PKCE clients.
# Exactly one of OIDC_CLIENT_SECRET or MCP_JWT_SIGNING_KEY must be set in HTTP mode.
# OIDC_CLIENT_SECRET=<...>

# Required when the Cognito app client is public (no secret). Generates the
# entropy used to sign FastMCP-issued JWTs and to derive the Fernet key for
# MCP_OAUTH_STORAGE_URL. Must be high-entropy and stable — rotating it
# invalidates any persisted OAuth state. Generate with `openssl rand -hex 32`.
# When OIDC_CLIENT_SECRET is also set, that secret wins as the storage Fernet
# key material; MCP_JWT_SIGNING_KEY only kicks in for sandbox/public deploys.
# MCP_JWT_SIGNING_KEY=<openssl rand -hex 32>

# DCR redirect allow-list — restricts which redirect URIs MCP clients may
# register at /register. Unset/empty → localhost-only defaults
# (http://localhost:*/*, http://127.0.0.1:*/*) which cover Claude Desktop,
# Cursor, and MCP Inspector on a developer laptop. Add server-side MCP
# clients (e.g. an AI app deployed at https://askii.moneta.dev) explicitly.
# MCP_ALLOWED_CLIENT_REDIRECT_URIS=http://localhost:*/*,http://127.0.0.1:*/*,https://askii.moneta.dev/*

# OAuth state storage. Unset → FastMCP keeps state in an encrypted file
# tree under ~/.local/share/fastmcp/oauth-proxy/ inside the container,
# which is wiped on container recreation. Set to a Valkey/Redis URL to
# persist state across redeploys and (with shared storage) enable
# horizontal scaling. The Moneta devstack wires this to the shared Valkey
# on a dedicated DB; standalone deployments should point at their own
# instance. State at rest is Fernet-encrypted using a key derived from
# MCP_JWT_SIGNING_KEY (preferred) or OIDC_CLIENT_SECRET (fallback). Rotating
# whichever one is in use invalidates stored sessions.
# Caveat: with `--maxmemory-policy allkeys-lru` (devstack default) Valkey
# can evict OAuth state under memory pressure regardless of TTL; for
# high-traffic prod, bump --maxmemory or switch to volatile-lru.
# MCP_OAUTH_STORAGE_URL=redis://valkey:6379/11

# HTTP listener port (default 8211). The Dockerfile sets this and the
# HEALTHCHECK reads it, so overriding here is sufficient — no rebuild needed.
# MCP_HTTP_PORT=8211

# Include tool request/response payloads in structured logs. Default is off
# because payloads can contain chat prompts, document bodies, and base64
# uploads (up to 500 MB) — keep it off in production. Truthy values: 1,
# true, yes, on. Useful for short debugging windows only.
# MCP_LOG_PAYLOADS=0

# Log level. Unset → derived from MCP_ENV:
#   MCP_ENV=production  → INFO
#   anything else       → DEBUG
# Set explicitly to override the env-derived default. Case-insensitive.
# Accepted: DEBUG, INFO, WARNING, ERROR, CRITICAL. Bogus values warn at
# startup and fall through to the MCP_ENV-derived default.
# MCP_LOG_LEVEL=INFO
