# Development Dockerfile for surfsense-mcp.
#
# Bakes a LOCAL moneta-mcp-auth checkout into the image instead of pulling
# it from PyPI. Use this when you're editing both surfsense-mcp-server AND
# moneta-mcp-auth and want the lib changes baked into a devstack image.
#
# Requires `docker buildx` and a `--build-context` pointing at the sibling
# moneta-mcp-auth checkout:
#
#   cd surfsense-mcp-server
#   docker buildx build \
#       --build-context monetaauth=../moneta-mcp-auth \
#       -f Dockerfile.dev \
#       -t ghcr.io/pressingly/surfsense-mcp:dev-local .
#
# Or via the devstack:
#
#   make dev.clone.lib                       # one-time clone alongside surfsense-mcp-server
#   make dev.build.surfsense.mcp.local       # builds with this Dockerfile
#   echo SURFSENSE_MCP_IMAGE=...:dev-local >> .env
#   make dev.restart.mcp
#
# Production builds use `Dockerfile` (no --build-context), which pulls
# moneta-mcp-auth from PyPI per the pinned version range.

# syntax=docker/dockerfile:1.7
ARG PYTHON_VERSION=3.11

# ---------- builder ----------
FROM python:${PYTHON_VERSION}-slim AS builder
WORKDIR /src

RUN pip install --no-cache-dir --upgrade pip build

# Sibling shared lib pulled in via --build-context monetaauth=...
COPY --from=monetaauth . /src/_monetaauth/
RUN cd /src/_monetaauth && python -m build --wheel --outdir /dist-lib

# Then this package.
COPY pyproject.toml README.md /src/
COPY surfsense_mcp /src/surfsense_mcp/
RUN python -m build --wheel --outdir /dist-app

# ---------- runtime ----------
FROM python:${PYTHON_VERSION}-slim AS runtime
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
      curl \
    && rm -rf /var/lib/apt/lists/*

# Install the local lib FIRST so the app's resolver finds it and skips PyPI.
COPY --from=builder /dist-lib/*.whl /tmp/lib/
COPY --from=builder /dist-app/*.whl /tmp/app/
RUN pip install --no-cache-dir /tmp/lib/*.whl /tmp/app/*.whl && rm -rf /tmp/lib /tmp/app

RUN groupadd --system --gid 10001 mcp \
 && useradd  --system --uid 10001 --gid mcp --home-dir /app --no-create-home mcp \
 && chown -R mcp:mcp /app
USER mcp

EXPOSE 8211
ENV MCP_HTTP_PORT=8211

ENTRYPOINT ["python", "-m", "surfsense_mcp"]
CMD ["http"]

HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=10 \
    CMD curl -fsS "http://127.0.0.1:${MCP_HTTP_PORT:-8211}/healthz" || exit 1
